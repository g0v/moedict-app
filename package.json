		"fuse.js": "^7.1.0",
		"react": "^19.1.1",
		"react-dom": "^19.1.1",
		"react-router-dom": "^7.13.1"
	},
	"devDependencies": {
		"@capacitor/android": "^7.2.0",
		"@capacitor/cli": "^7.2.0",
		"@capacitor/core": "^7.2.0",
		"@types/react": "^19.1.10",
		"@types/react-dom": "^19.1.7",
		"@vitejs/plugin-react": "^5.0.0",
		"typescript": "~5.8.3",
		"vite": "^7.1.2"
	}
}
